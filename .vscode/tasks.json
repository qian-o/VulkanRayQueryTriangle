{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "powershell.exe",
            "type": "process",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/build.ps1"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "validate SPIR-V",
            "command": "${env:VULKAN_SDK}/Bin/spirv-val.exe",
            "type": "process",
            "args": [
                "--target-env",
                "vulkan1.4",
                "${workspaceFolder}/ray_query_heap.spv"
            ],
            "problemMatcher": []
        }
    ]
}
